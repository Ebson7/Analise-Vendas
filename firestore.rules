rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Deny by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Sellers schema enforcement
    match /sellers/{sellerId} {
      allow read, list: if true;
      allow create: if isValidId(sellerId) && isValidSeller(request.resource.data);
      allow update: if isValidId(sellerId) && isValidSeller(request.resource.data);
      allow delete: if isValidId(sellerId);
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidSeller(data) {
      return data.keys().hasAll(['id', 'sellerName', 'city', 'segment', 'currentClients', 'createdAt'])
        && data.keys().size() <= 8
        && data.id is string && data.id.size() <= 128
        && data.sellerName is string && data.sellerName.size() <= 200
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 40))
        && data.city is string && data.city.size() <= 200
        && data.segment is string && data.segment.size() <= 100
        && data.currentClients is number
        && data.createdAt is string;
    }
  }
}
